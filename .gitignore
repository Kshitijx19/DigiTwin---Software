# =========================
# DigiTwin - Git Ignore
# =========================

# ---------- Python ----------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
*.egg-info/
.eggs/

# Virtual environments
venv/
.venv/
env/
ENV/

# Python packaging
dist/
build/
pip-wheel-metadata/

# ---------- FastAPI / Uvicorn ----------
*.log
uvicorn.log

# ---------- Environment variables ----------
.env
.env.local
.env.*.local

# ---------- SQLite / Database ----------
*.db
*.sqlite
*.sqlite3

# ---------- Node / React / Vite ----------
node_modules/
dist/
build/
coverage/
.vite/
vite.svg
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Frontend environment ----------
frontend/.env
frontend/.env.local
frontend/.env.*.local

# ---------- Backend environment ----------
backend/.env
backend/.env.local
backend/.env.*.local

# ---------- OS files ----------
.DS_Store
Thumbs.db

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------- Logs / Temp ----------
logs/
tmp/
temp/
*.tmp

# ---------- Generated docs / reports ----------
docs/**/output/
docs/**/generated/
docs/**/*.pdf
docs/**/*.docx
docs/**/*.pptx

# ---------- Misc ----------
*.bak
*.orig